{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://twelia.app/schemas/mod-manifest-v1.json",
  "title": "Twelia mod manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "name", "version", "apiVersion", "entry", "capabilities"],
  "allOf": [
    {
      "if": {
        "properties": { "capabilities": { "contains": { "const": "network" } } }
      },
      "then": {
        "required": ["network"],
        "properties": { "network": { "minItems": 1 } }
      },
      "else": { "properties": { "network": { "maxItems": 0 } } }
    },
    {
      "if": {
        "properties": { "capabilities": { "contains": { "const": "game-entry" } } }
      },
      "then": { "required": ["gameEntry"] },
      "else": { "not": { "required": ["gameEntry"] } }
    },
    {
      "if": {
        "properties": { "capabilities": { "contains": { "const": "secrets" } } }
      },
      "else": {
        "properties": {
          "settings": {
            "additionalProperties": {
              "not": {
                "properties": { "type": { "const": "secret" } },
                "required": ["type"]
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!.*\\.\\.)[a-z0-9](?:[a-z0-9.-]*[a-z0-9])?$"
    },
    "name": { "type": "string", "minLength": 1, "maxLength": 80 },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "apiVersion": { "const": 1 },
    "entry": { "$ref": "#/$defs/entry" },
    "gameEntry": { "$ref": "#/$defs/entry" },
    "network": {
      "type": "array",
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "format": "uri",
        "pattern": "^https://(?![^/?#]*@)[^/?#]+/?$"
      }
    },
    "capabilities": {
      "type": "array",
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "enum": [
          "network",
          "notifications",
          "clipboard.write",
          "files.user-selected",
          "secrets",
          "game-entry"
        ]
      }
    },
    "settings": {
      "type": "object",
      "maxProperties": 64,
      "propertyNames": { "pattern": "^[A-Za-z0-9._-]{1,64}$" },
      "additionalProperties": { "$ref": "#/$defs/setting" }
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 500 },
    "author": { "type": "string", "minLength": 1, "maxLength": 120 },
    "homepage": { "type": "string", "format": "uri", "pattern": "^https://" },
    "license": { "type": "string", "minLength": 1, "maxLength": 80 },
    "repository": { "type": "string", "format": "uri", "pattern": "^https://" },
    "minTweliaVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$"
    }
  },
  "$defs": {
    "entry": {
      "type": "string",
      "pattern": "^(?![./])(?!.*//)(?!.*(?:^|/)\\.{1,2}(?:/|$))[^\\\\]+\\.js$"
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "label"],
      "properties": {
        "value": { "type": "string", "minLength": 1, "maxLength": 128 },
        "label": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "setting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": { "enum": ["boolean", "string", "number", "select", "secret"] },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "description": { "type": "string", "minLength": 1, "maxLength": 500 },
        "default": {},
        "placeholder": { "type": "string", "minLength": 1, "maxLength": 200 },
        "minimum": { "type": "number" },
        "maximum": { "type": "number" },
        "step": { "type": "number", "exclusiveMinimum": 0 },
        "options": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/option" }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "select" } } },
          "then": { "required": ["options"] },
          "else": { "properties": { "options": { "maxItems": 0 } } }
        },
        {
          "if": { "properties": { "type": { "const": "boolean" } } },
          "then": { "properties": { "default": { "type": "boolean" } } }
        },
        {
          "if": { "properties": { "type": { "const": "string" } } },
          "then": {
            "properties": { "default": { "type": "string", "maxLength": 4096 } }
          }
        },
        {
          "if": { "properties": { "type": { "const": "number" } } },
          "then": { "properties": { "default": { "type": "number" } } },
          "else": {
            "not": {
              "anyOf": [
                { "required": ["minimum"] },
                { "required": ["maximum"] },
                { "required": ["step"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "select" } } },
          "then": { "properties": { "default": { "type": "string" } } }
        },
        {
          "if": { "properties": { "type": { "const": "secret" } } },
          "then": { "not": { "required": ["default"] } }
        }
      ]
    }
  }
}
